<div class="sidebar" id="sidebar">
    <a href="/home" class="logo">DealerX</a>

    <a href="/home" class="<%= page === 'home' ? 'active' : '' %>">
        <i class="fa-solid fa-house"></i>
        <span class="lang-text" data-en="Home" data-ar="الرئيسية">Home</span>
    </a>

    <a href="/servers" class="<%= page === 'servers' ? 'active' : '' %>">
        <i class="fa-solid fa-server"></i>
        <span class="lang-text" data-en="Servers" data-ar="السيرفرات">Servers</span>
    </a>

    <a href="/premium" class="<%= page === 'premium' ? 'active' : '' %>">
        <i class="fa-solid fa-crown"></i>
        <span class="lang-text" data-en="Premium" data-ar="البريميام">Premium</span>
    </a>

    <% if (typeof isBotOwner !== "undefined" && isBotOwner) { %>
        <a href="/owner" class="<%= page === 'owner' ? 'active' : '' %>">
            <i class="fa-solid fa-user-shield"></i>
            <span class="lang-text" data-en="Admin Panel" data-ar="لوحة الإدارة">Admin Panel</span>
        </a>
    <% } %>

    <a href="#" class="<%= page === 'settings' ? 'active' : '' %>">
        <i class="fa-solid fa-gear"></i>
        <span class="lang-text" data-en="Settings" data-ar="الإعدادات">Settings</span>
    </a>

    <a href="/logout" style="margin-top: 40px; color: #ff5a5a;">
        <i class="fa-solid fa-arrow-right-from-bracket"></i>
        <span class="lang-text" data-en="Logout" data-ar="تسجيل الخروج">Logout</span>
    </a>
</div>
