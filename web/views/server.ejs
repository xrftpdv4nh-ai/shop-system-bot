<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>DealerX | <%= guild.name %></title>
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.2/css/all.min.css">
    <link rel="stylesheet" href="/style.css">
</head>
<body>
    <div class="overlay" id="overlay" onclick="toggleSidebar()"></div>

    <%- include('sidebar', { page: 'servers' }) %>

    <div class="main" id="main">
        <div class="navbar dashboard-navbar">
            <i class="fa-solid fa-bars toggle-btn" onclick="toggleSidebar()"></i>

            <div class="user-section">
                <span class="username"><%= user.username %></span>
                <img
                    src="<%= user.avatar ? `https://cdn.discordapp.com/avatars/${user.discordId}/${user.avatar}.png` : 'https://cdn.discordapp.com/embed/avatars/0.png' %>"
                    class="avatar"
                    alt="avatar"
                    onerror="this.src='https://cdn.discordapp.com/embed/avatars/0.png'"
                >
            </div>
        </div>

        <div class="content">
            <div class="page-header">
                <h2>Manage Server <i class="fa-solid fa-sliders" style="color:var(--main-red); font-size:20px;"></i></h2>
                <p>Configure each command with its own permissions, channels and alias.</p>
            </div>

            <div class="grid">
                <!-- Server Info -->
                <div class="card" style="grid-column: span 12; text-align:left; padding:28px;">
                    <div style="display:flex; align-items:center; gap:18px; flex-wrap:wrap;">
                        <% if (guild.icon) { %>
                            <img
                                src="https://cdn.discordapp.com/icons/<%= guild.id %>/<%= guild.icon %>.png"
                                class="server-icon"
                                style="margin:0; width:92px; height:92px;"
                            >
                        <% } else { %>
                            <div class="server-icon-fallback" style="margin:0; width:92px; height:92px;">
                                <%= guild.name.charAt(0) %>
                            </div>
                        <% } %>

                        <div style="flex:1;">
                            <h3 style="margin:0 0 8px; font-size:28px; color:white; font-weight:900;">
                                <%= guild.name %>
                            </h3>
                            <p style="margin:0 0 10px; color:#9f9f9f;">Guild ID: <%= guild.id %></p>

                            <div style="display:flex; gap:10px; flex-wrap:wrap;">
                                <span style="background:rgba(255,30,46,0.10); color:#ffb1b7; border:1px solid rgba(255,30,46,0.18); padding:8px 12px; border-radius:999px; font-size:13px; font-weight:700;">
                                    DealerX Command Panel
                                </span>

                                <span style="background:rgba(255,255,255,0.04); color:#d3d3d3; border:1px solid rgba(255,255,255,0.06); padding:8px 12px; border-radius:999px; font-size:13px; font-weight:700;">
                                    Saved Config Active
                                </span>
                            </div>
                        </div>
                    </div>
                </div>

                <% const commandList = ['profile', 'crowns', 'daily', 'top', 'leaderboard']; %>
                <% commandList.forEach(cmd => { 
                    const settings = (config.commandSettings && config.commandSettings[cmd]) || {};
                %>
                    <div class="card" style="grid-column: span 12; text-align:left; padding:26px;">
                        <form action="/server/<%= guild.id %>/settings/<%= cmd %>" method="POST">
                            <div style="display:flex; justify-content:space-between; align-items:flex-start; gap:14px; flex-wrap:wrap; margin-bottom:18px;">
                                <div>
                                    <h3 style="margin:0 0 8px; color:white; font-size:30px; font-weight:900;">/<%= cmd %></h3>
                                    <p style="margin:0; color:#a8a8a8; line-height:1.7;">
                                        Configure permissions, allowed channels, and a custom alias for this command.
                                    </p>
                                </div>

                                <label style="display:flex; align-items:center; gap:10px; color:white; font-weight:800; background:rgba(255,255,255,0.03); padding:12px 14px; border-radius:14px; border:1px solid rgba(255,30,46,0.08);">
                                    <input
                                        type="checkbox"
                                        name="disabled"
                                        <%= settings.disabled ? 'checked' : '' %>
                                        style="width:20px; height:20px;"
                                    >
                                    Disable
                                </label>
                            </div>

                            <div style="display:grid; gap:18px;">
                                <!-- Allowed Roles -->
                                <div style="background:rgba(255,255,255,0.02); border:1px solid rgba(255,30,46,0.08); border-radius:18px; padding:16px;">
                                    <div style="display:flex; align-items:center; justify-content:space-between; gap:10px; flex-wrap:wrap;">
                                        <div>
                                            <h4 style="margin:0 0 6px; color:white; font-size:22px;">Allowed Roles</h4>
                                            <p style="margin:0; color:#9f9f9f; font-size:14px;">
                                                Choose which roles can use this command.
                                            </p>
                                        </div>

                                        <button
                                            type="button"
                                            class="btn-manage"
                                            style="max-width:220px;"
                                            onclick="toggleBox('roles-<%= cmd %>')"
                                        >
                                            <i class="fa-solid fa-user-shield"></i>
                                            Select Roles
                                        </button>
                                    </div>

                                    <div
                                        id="roles-<%= cmd %>"
                                        style="display:none; margin-top:14px; max-height:280px; overflow:auto; background:rgba(255,255,255,0.02); border:1px solid rgba(255,30,46,0.08); border-radius:16px; padding:12px;"
                                    >
                                        <div style="display:grid; gap:10px;">
                                            <% roles.forEach(role => { %>
                                                <label style="display:flex; align-items:center; gap:10px; background:rgba(255,255,255,0.03); padding:12px; border-radius:12px; border:1px solid rgba(255,30,46,0.08); color:white;">
                                                    <input
                                                        type="checkbox"
                                                        name="roles"
                                                        value="<%= role.id %>"
                                                        <%= (settings.roles || []).includes(role.id) ? 'checked' : '' %>
                                                    >
                                                    <%= role.name %>
                                                </label>
                                            <% }) %>
                                        </div>
                                    </div>
                                </div>

                                <!-- Allowed Channels -->
                                <div style="background:rgba(255,255,255,0.02); border:1px solid rgba(255,30,46,0.08); border-radius:18px; padding:16px;">
                                    <div style="display:flex; align-items:center; justify-content:space-between; gap:10px; flex-wrap:wrap;">
                                        <div>
                                            <h4 style="margin:0 0 6px; color:white; font-size:22px;">Allowed Channels</h4>
                                            <p style="margin:0; color:#9f9f9f; font-size:14px;">
                                                Choose which channels can use this command.
                                            </p>
                                        </div>

                                        <button
                                            type="button"
                                            class="btn-manage"
                                            style="max-width:240px;"
                                            onclick="toggleBox('channels-<%= cmd %>')"
                                        >
                                            <i class="fa-solid fa-hashtag"></i>
                                            Select Channels
                                        </button>
                                    </div>

                                    <div
                                        id="channels-<%= cmd %>"
                                        style="display:none; margin-top:14px; max-height:280px; overflow:auto; background:rgba(255,255,255,0.02); border:1px solid rgba(255,30,46,0.08); border-radius:16px; padding:12px;"
                                    >
                                        <div style="display:grid; gap:10px;">
                                            <% channels.forEach(channel => { %>
                                                <label style="display:flex; align-items:center; gap:10px; background:rgba(255,255,255,0.03); padding:12px; border-radius:12px; border:1px solid rgba(255,30,46,0.08); color:white;">
                                                    <input
                                                        type="checkbox"
                                                        name="channels"
                                                        value="<%= channel.id %>"
                                                        <%= (settings.channels || []).includes(channel.id) ? 'checked' : '' %>
                                                    >
                                                    #<%= channel.name %>
                                                </label>
                                            <% }) %>
                                        </div>
                                    </div>
                                </div>

                                <!-- Alias -->
                                <div style="background:rgba(255,255,255,0.02); border:1px solid rgba(255,30,46,0.08); border-radius:18px; padding:16px;">
                                    <h4 style="margin:0 0 10px; color:white; font-size:22px;">Command Alias</h4>
                                    <input
                                        type="text"
                                        name="alias"
                                        value="<%= settings.alias || '' %>"
                                        placeholder="Example: p or c"
                                        style="width:100%; padding:14px; border-radius:12px; border:1px solid rgba(255,30,46,0.12); background:#111; color:white; outline:none;"
                                    >
                                    <p style="margin:10px 0 0; color:#9f9f9f; font-size:13px; line-height:1.7;">
                                        If you enter an alias here, users can type it in chat and the bot will respond as if the real command was used.
                                        Example: alias <strong style="color:white;">c</strong> for <strong style="color:white;">/crowns</strong>.
                                    </p>
                                </div>
                            </div>

                            <div style="margin-top:20px;">
                                <button type="submit" class="btn-manage" style="max-width:260px;">
                                    <i class="fa-solid fa-floppy-disk"></i>
                                    Save /<%= cmd %>
                                </button>
                            </div>
                        </form>
                    </div>
                <% }) %>
            </div>
        </div>
    </div>

    <script>
        function toggleSidebar() {
            const sidebar = document.getElementById("sidebar");
            const main = document.getElementById("main");
            const overlay = document.getElementById("overlay");

            if (window.innerWidth <= 768) {
                sidebar.classList.toggle("active");
                overlay.classList.toggle("active");
            } else {
                sidebar.classList.toggle("collapsed");
                main.classList.toggle("collapsed");
            }
        }

        function toggleBox(id) {
            const box = document.getElementById(id);
            if (!box) return;

            box.style.display = box.style.display === "none" || box.style.display === "" ? "block" : "none";
        }
    </script>
</body>
</html>
