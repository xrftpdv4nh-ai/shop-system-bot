<!DOCTYPE html>
<html lang="en" id="htmlLang" dir="ltr">
<head>
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">
    <link rel="stylesheet" href="/style.css">
</head>
<body>
    <%- include('sidebar', { page: 'home' }) %>

    <div class="main" id="main">
        <%- include('navbar') %>

        <div class="content" style="text-align: center; padding-top: 50px;">
            <h1 style="color: var(--main-red);">DealerX Bot</h1>
            <p>The ultimate management solution for your discord server.</p>

            <% if (user) { %>
                <p style="margin-top: 20px;">Welcome back, <strong><%= user.username %></strong>.</p>
            <% } %>

            <div class="grid" style="grid-template-columns: repeat(auto-fit, minmax(200px, 1fr)); margin-top: 40px;">
                <div class="card">
                    <i class="fa-solid fa-server" style="font-size: 30px; color: var(--main-red);"></i>
                    <h3>150+ Servers</h3>
                </div>
                <div class="card">
                    <i class="fa-solid fa-users" style="font-size: 30px; color: var(--main-red);"></i>
                    <h3>50k+ Users</h3>
                </div>
                <div class="card">
                    <i class="fa-solid fa-check-double" style="font-size: 30px; color: var(--main-red);"></i>
                    <h3>99.9% Uptime</h3>
                </div>
            </div>
        </div>
    </div>
</body>
</html>
