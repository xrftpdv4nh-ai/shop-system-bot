<!DOCTYPE html>
<html lang="en" id="htmlRoot" dir="ltr">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>DealerX | Servers</title>
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">
    <link rel="stylesheet" href="/style.css">
</head>
<body>

    <div class="overlay" id="overlay" onclick="toggleSidebar()"></div>

    <%- include('sidebar', { page: 'servers' }) %>

    <div class="main" id="main">
        <div class="navbar dashboard-navbar">
            <i class="fa-solid fa-bars toggle-btn" onclick="toggleSidebar()"></i>

            <div class="user-section">
                <select id="languageSwitcher" class="lang-select" onchange="setLanguage(this.value)">
                    <option value="en">English</option>
                    <option value="ar">العربية</option>
                </select>

                <span class="username"><%= user.username %></span>

                <img
                    src="<%= user.avatar ? `https://cdn.discordapp.com/avatars/${user.discordId}/${user.avatar}.png` : 'https://cdn.discordapp.com/embed/avatars/0.png' %>"
                    class="avatar"
                    alt="avatar"
                    onerror="this.src='https://cdn.discordapp.com/embed/avatars/0.png'"
                >
            </div>
        </div>

        <div class="content">
            <div class="page-header">
                <h2>
                    <span class="lang-text" data-en="Your Servers" data-ar="سيرفراتك">Your Servers</span>
                    <i class="fa-solid fa-server" style="color:var(--main-red); font-size:20px;"></i>
                </h2>

                <p class="lang-text" data-en="Choose the server you want to manage" data-ar="اختر السيرفر الذي تريد إدارته">
                    Choose the server you want to manage
                </p>
            </div>

            <div class="grid">
                <% if (!guilds.length) { %>
                    <div class="card">
                        <i class="fa-solid fa-circle-info fa-2x" style="color: var(--main-red); margin-bottom: 15px;"></i>
                        <h3 class="lang-text" data-en="No Servers Found" data-ar="لا توجد سيرفرات">No Servers Found</h3>
                        <p class="lang-text" data-en="No available guilds to manage right now" data-ar="لا توجد سيرفرات متاحة للإدارة الآن">
                            No available guilds to manage right now
                        </p>
                    </div>
                <% } %>

                <% guilds.forEach(guild => { %>
                    <div class="card">
                        <% if (guild.icon) { %>
                            <img src="https://cdn.discordapp.com/icons/<%= guild.id %>/<%= guild.icon %>.png" class="server-icon">
                        <% } else { %>
                            <div class="server-icon-fallback"><%= guild.name.charAt(0) %></div>
                        <% } %>

                        <h3 class="guild-name"><%= guild.name %></h3>
                        <p class="guild-id">ID: <%= guild.id %></p>

                        <a href="/server/<%= guild.id %>" class="btn-manage">
                            <span class="lang-text" data-en="Manage Server" data-ar="إدارة السيرفر">Manage Server</span>
                        </a>
                    </div>
                <% }) %>
            </div>
        </div>
    </div>

    <script>
        function toggleSidebar() {
            const sidebar = document.getElementById("sidebar");
            const main = document.getElementById("main");
            const overlay = document.getElementById("overlay");

            if (window.innerWidth <= 768) {
                sidebar.classList.toggle("active");
                overlay.classList.toggle("active");
            } else {
                sidebar.classList.toggle("collapsed");
                main.classList.toggle("collapsed");
            }
        }

        function applyLanguage(lang) {
            const root = document.getElementById("htmlRoot");
            const switcher = document.getElementById("languageSwitcher");
            const elements = document.querySelectorAll(".lang-text");

            if (lang === "ar") {
                root.setAttribute("lang", "ar");
                root.setAttribute("dir", "rtl");
            } else {
                root.setAttribute("lang", "en");
                root.setAttribute("dir", "ltr");
            }

            elements.forEach(el => {
                el.textContent = el.getAttribute(`data-${lang}`);
            });

            if (switcher) switcher.value = lang;
            localStorage.setItem("siteLang", lang);
        }

        function setLanguage(lang) {
            applyLanguage(lang);
        }

        const savedLang = localStorage.getItem("siteLang") || "en";
        applyLanguage(savedLang);
    </script>
</body>
</html>
