<!DOCTYPE html>
<html lang="en" id="htmlLang" dir="ltr">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>DealerX | Dashboard</title>
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">
    <style>
        :root {
            --main-red: #ff1e2e;
            --main-red-hover: #cc1825;
            --bg-dark: #0b0b0b;
            --sidebar-bg: #121212;
            --card-bg: rgba(255, 255, 255, 0.03);
            --border-color: rgba(255, 30, 46, 0.15);
            --sidebar-width: 260px;
        }

        body {
            margin: 0; font-family: 'Segoe UI', Tahoma, Geneva, Verdana, sans-serif;
            background: var(--bg-dark); color: white; overflow-x: hidden;
            transition: 0.3s;
        }

        /* القائمة الجانبية (متجاوبة مع اللغتين بذكاء) */
        .sidebar {
            width: var(--sidebar-width); background: var(--sidebar-bg);
            height: 100vh; position: fixed; top: 0;
            inset-inline-start: 0; /* ده السحر اللي بيخليها يمين في العربي وشمال في الإنجليزي */
            border-inline-end: 1px solid var(--border-color);
            transition: transform 0.4s cubic-bezier(0.175, 0.885, 0.32, 1);
            z-index: 1000; overflow-y: auto;
        }

        .sidebar .logo {
            font-size: 26px; font-weight: 800; color: var(--main-red);
            text-align: center; padding: 25px 0; display: block;
            text-decoration: none; letter-spacing: 1px;
            border-bottom: 1px solid var(--border-color);
        }

        .sidebar a {
            display: flex; align-items: center; gap: 15px;
            padding: 16px 25px; color: #aaa; text-decoration: none;
            font-weight: 500; transition: 0.3s;
            border-inline-start: 4px solid transparent;
        }

        .sidebar a:hover, .sidebar a.active {
            background: rgba(255, 30, 46, 0.08); color: var(--main-red);
            border-inline-start: 4px solid var(--main-red);
        }

        .sidebar a i { font-size: 18px; width: 20px; text-align: center; }

        /* المحتوى الرئيسي */
        .main {
            margin-inline-start: var(--sidebar-width); 
            transition: 0.4s ease; min-height: 100vh;
        }

        /* الناف بار */
        .navbar {
            display: flex; justify-content: space-between; align-items: center;
            padding: 15px 30px; background: rgba(11, 11, 11, 0.8);
            backdrop-filter: blur(10px); border-bottom: 1px solid var(--border-color);
            position: sticky; top: 0; z-index: 100;
        }

        .toggle-btn { font-size: 24px; cursor: pointer; color: white; transition: 0.3s; }
        .toggle-btn:hover { color: var(--main-red); }

        .user-section { display: flex; align-items: center; gap: 15px; }
        .lang-btn {
            background: transparent; border: 1px solid var(--main-red); color: var(--main-red);
            padding: 6px 12px; border-radius: 6px; cursor: pointer; font-weight: bold; transition: 0.3s;
        }
        .lang-btn:hover { background: var(--main-red); color: white; }
        .avatar { width: 38px; height: 38px; border-radius: 50%; border: 2px solid var(--main-red); }

        /* الكروت والمحتوى */
        .content { padding: 40px; }
        .page-header { border-inline-start: 4px solid var(--main-red); padding-inline-start: 15px; }
        
        .grid {
            display: grid; grid-template-columns: repeat(auto-fill, minmax(280px, 1fr));
            gap: 25px; margin-top: 30px;
        }

        .card {
            background: var(--card-bg); border: 1px solid var(--border-color);
            padding: 25px; border-radius: 16px; text-align: center;
            transition: 0.3s; position: relative; overflow: hidden;
        }
        .card:hover { border-color: var(--main-red); transform: translateY(-5px); box-shadow: 0 5px 20px rgba(255, 30, 46, 0.1); }

        .server-icon, .server-icon-fallback {
            width: 70px; height: 70px; border-radius: 50%; margin: 0 auto 15px auto;
            border: 2px solid var(--border-color); object-fit: cover;
        }
        .server-icon-fallback {
            background: #222; display: flex; align-items: center; justify-content: center;
            font-size: 28px; font-weight: bold;
        }

        .btn {
            background: linear-gradient(90deg, #c1121f, var(--main-red)); color: white;
            padding: 12px; border-radius: 8px; text-decoration: none; display: block;
            font-weight: bold; transition: 0.3s;
        }
        .btn:hover { filter: brightness(1.2); box-shadow: 0 4px 15px rgba(255, 30, 46, 0.3); }

        /* Overlay */
        .overlay {
            position: fixed; top: 0; left: 0; width: 100%; height: 100%;
            background: rgba(0,0,0,0.6); z-index: 999; display: none; opacity: 0; transition: 0.3s;
        }

        /* كلاسات التحكم في الإخفاء والإظهار */
        .sidebar.collapsed { transform: translateX(-100%); }
        [dir="rtl"] .sidebar.collapsed { transform: translateX(100%); }
        .main.collapsed { margin-inline-start: 0; }

        @media (max-width: 768px) {
            .sidebar { transform: translateX(-100%); } 
            [dir="rtl"] .sidebar { transform: translateX(100%); }
            
            .sidebar.active { transform: translateX(0) !important; }
            .main { margin-inline-start: 0; }
            .content { padding: 20px; }
            .overlay.active { display: block; opacity: 1; }
        }
    </style>
</head>
<body>

    <div class="overlay" id="overlay" onclick="toggleSidebar()"></div>

    <div class="sidebar" id="sidebar">
        <a href="/" class="logo">DealerX</a>
        <a href="/dashboard" class="active">
            <i class="fa-solid fa-house"></i> 
            <span class="lang" data-en="Home" data-ar="الرئيسية">Home</span>
        </a>
        <a href="#">
            <i class="fa-solid fa-shield-halved"></i> 
            <span class="lang" data-en="Servers" data-ar="السيرفرات">Servers</span>
        </a>
        <a href="#">
            <i class="fa-solid fa-gear"></i> 
            <span class="lang" data-en="Settings" data-ar="الإعدادات">Settings</span>
        </a>
        <a href="#">
            <i class="fa-solid fa-robot"></i> 
            <span class="lang" data-en="Commands" data-ar="الأوامر">Commands</span>
        </a>
        <a href="/logout" style="margin-top: 50px; color: #ff4d4d;">
            <i class="fa-solid fa-arrow-right-from-bracket"></i> 
            <span class="lang" data-en="Logout" data-ar="تسجيل الخروج">Logout</span>
        </a>
    </div>

    <div class="main" id="main">
        
        <div class="navbar">
            <i class="fa-solid fa-bars toggle-btn" onclick="toggleSidebar()"></i>
            
            <div class="user-section">
                <button class="lang-btn" onclick="toggleLang()" id="langBtn">AR</button>
                <span style="font-weight: bold;"><%= user.username %></span>
                <img src="https://cdn.discordapp.com/avatars/<%=user.id%>/<%=user.avatar%>.png" class="avatar" onerror="this.src='https://cdn.discordapp.com/embed/avatars/0.png'">
            </div>
        </div>

        <div class="content">
            <div class="page-header">
                <h2 style="margin: 0 0 5px 0;">
                    <span class="lang" data-en="Your Servers" data-ar="سيرفراتك">Your Servers</span> 
                    <i class="fa-solid fa-server" style="color:var(--main-red); font-size:20px;"></i>
                </h2>
                <p class="lang" data-en="Choose the server you want to manage" data-ar="اختر السيرفر الذي تود إدارته" style="color:#888; margin: 0;">
                    Choose the server you want to manage
                </p>
            </div>

            <div class="grid">
                <% guilds.forEach(guild => { %>
                    <div class="card">
                        <% if (guild.icon) { %>
                            <img src="https://cdn.discordapp.com/icons/<%= guild.id %>/<%= guild.icon %>.png" class="server-icon">
                        <% } else { %>
                            <div class="server-icon-fallback"><%= guild.name.charAt(0) %></div>
                        <% } %>
                        
                        <h3 style="margin: 0 0 5px 0; font-size: 18px; white-space: nowrap; overflow: hidden; text-overflow: ellipsis;"><%= guild.name %></h3>
                        <p style="color: #666; font-size: 12px; margin: 0 0 20px 0;">ID: <%= guild.id %></p>
                        
                        <a href="/server/<%= guild.id %>" class="btn">
                            <i class="fa-solid fa-sliders"></i> 
                            <span class="lang" data-en="Manage Server" data-ar="إدارة السيرفر">Manage Server</span>
                        </a>
                    </div>
                <% }) %>
            </div>
        </div>

    </div>

    <script>
        /* كود التحكم في القائمة (Sidebar) المتوافق مع اللغتين */
        function toggleSidebar() {
            const sidebar = document.getElementById("sidebar");
            const main = document.getElementById("main");
            const overlay = document.getElementById("overlay");
            
            if (window.innerWidth <= 768) {
                sidebar.classList.toggle("active");
                overlay.classList.toggle("active");
            } else {
                sidebar.classList.toggle("collapsed");
                main.classList.toggle("collapsed");
            }
        }

        /* كود الترجمة الشامل (بضغطة زر) */
        let isArabic = false;
        function toggleLang() {
            isArabic = !isArabic;
            const htmlTag = document.getElementById("htmlLang");
            const langBtn = document.getElementById("langBtn");
            const translatableElements = document.querySelectorAll(".lang");

            if(isArabic) {
                htmlTag.setAttribute("dir", "rtl"); // بيقلب الموقع يمين
                htmlTag.setAttribute("lang", "ar");
                langBtn.innerText = "EN"; // يخلي الزرار يقلب إنجليزي
                
                // بيغير كل الكلمات لعربي
                translatableElements.forEach(el => {
                    el.innerHTML = el.getAttribute("data-ar");
                });
            } else {
                htmlTag.setAttribute("dir", "ltr"); // بيقلب الموقع شمال
                htmlTag.setAttribute("lang", "en");
                langBtn.innerText = "AR"; // يخلي الزرار يقلب عربي
                
                // بيغير كل الكلمات لإنجليزي
                translatableElements.forEach(el => {
                    el.innerHTML = el.getAttribute("data-en");
                });
            }
        }
    </script>
</body>
</html>
