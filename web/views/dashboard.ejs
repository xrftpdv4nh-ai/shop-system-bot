<!DOCTYPE html>
<html lang="en" id="htmlLang" dir="ltr">
<head>
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">
    <link rel="stylesheet" href="/style.css">
</head>
<body>
    <%- include('sidebar', { page: 'dashboard' }) %>

    <div class="main" id="main">
        <%- include('navbar') %>

        <div class="content">
            <h2>Your Managed Servers</h2>

            <% if (!guilds || guilds.length === 0) { %>
                <div class="card" style="margin-top: 20px;">
                    <p>No admin servers found for this account.</p>
                </div>
            <% } else { %>
                <div class="grid" style="margin-top: 20px; grid-template-columns: repeat(auto-fill, minmax(250px, 1fr));">
                    <% guilds.forEach(guild => { %>
                        <div class="card">
                            <h3><%= guild.name %></h3>
                            <p>ID: <%= guild.id %></p>
                        </div>
                    <% }) %>
                </div>
            <% } %>
        </div>
    </div>
</body>
</html>
