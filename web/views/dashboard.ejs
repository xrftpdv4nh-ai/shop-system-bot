<!DOCTYPE html>
<html lang="ar" dir="rtl">
<head>
    <link rel="stylesheet" href="/style.css">
    <title>DealerX | Dashboard</title>
</head>
<body>
    <div class="sidebar">
        <a href="/" class="logo">DealerX</a>
        <a href="/dashboard" class="nav-link active">الرئيسية</a>
        <a href="/profile" class="nav-link">حسابي</a>
        <a href="/logout" class="nav-link" style="margin-top:auto; color:#ff4d4d;">تسجيل الخروج</a>
    </div>

    <div class="main-content">
        <div style="display:flex; justify-content:space-between; align-items:center;">
            <h1>سيرفراتك</h1>
            <img src="https://cdn.discordapp.com/avatars/<%=user.id%>/<%=user.avatar%>.png" style="width:40px; border-radius:50%; border:2px solid var(--main-red);">
        </div>

        <div class="grid">
            <% guilds.forEach(guild => { %>
                <div class="card" style="border: 1px solid #333; padding: 20px; border-radius: 12px;">
                    <h3 style="margin-top:0"><%= guild.name %></h3>
                    <p style="font-size:12px; color:#666;"><%= guild.id %></p>
                    <a href="/server/<%= guild.id %>" class="btn primary" style="width:100%; text-align:center;">إدارة الإعدادات</a>
                </div>
            <% }) %>
        </div>
    </div>
</body>
</html>
