<div class="top-nav">
    <a href="/" class="brand">DealerX</a>

    <div class="top-nav-right">
        <% if (user) { %>
            <a href="/dashboard" class="nav-btn nav-btn-outline">Dashboard</a>

            <img
                src="<%= user.avatar ? `https://cdn.discordapp.com/avatars/${user.discordId}/${user.avatar}.png` : 'https://cdn.discordapp.com/embed/avatars/0.png' %>"
                class="nav-avatar"
                alt="avatar"
                onerror="this.src='https://cdn.discordapp.com/embed/avatars/0.png'"
            >
        <% } else { %>
            <a href="/login" class="nav-btn nav-btn-outline">Login</a>
        <% } %>
    </div>
</div>
