<!DOCTYPE html>
<html lang="en" id="htmlRoot" dir="ltr">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>DealerX | Home</title>
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">
    <link rel="stylesheet" href="/style.css">
</head>
<body>

    <div class="overlay" id="overlay" onclick="toggleSidebar()"></div>

    <%- include('sidebar', { page: 'home' }) %>

    <div class="main" id="main">
        <div class="navbar dashboard-navbar">
            <i class="fa-solid fa-bars toggle-btn" onclick="toggleSidebar()"></i>

            <div class="user-section">
                <select id="languageSwitcher" class="lang-select" onchange="setLanguage(this.value)">
                    <option value="en">English</option>
                    <option value="ar">العربية</option>
                </select>

                <span class="username"><%= user.username %></span>

                <img
                    src="<%= user.avatar ? `https://cdn.discordapp.com/avatars/${user.discordId}/${user.avatar}.png` : 'https://cdn.discordapp.com/embed/avatars/0.png' %>"
                    class="avatar"
                    alt="avatar"
                    onerror="this.src='https://cdn.discordapp.com/embed/avatars/0.png'"
                >
            </div>
        </div>

        <div class="content">
            <div class="page-header">
                <h2>
                    <span class="lang-text" data-en="Bot Overview" data-ar="نظرة عامة على البوت">Bot Overview</span>
                    <i class="fa-solid fa-robot" style="color:var(--main-red); font-size:20px;"></i>
                </h2>
                <p class="lang-text" data-en="Manage your bot, settings and language from one place" data-ar="تحكم في البوت والإعدادات ولغة الموقع من مكان واحد">
                    Manage your bot, settings and language from one place
                </p>
            </div>

            <div class="grid">
                <div class="card">
                    <i class="fa-solid fa-shield-halved fa-2x" style="color: var(--main-red); margin-bottom: 15px;"></i>
                    <h3 class="lang-text" data-en="Protection System" data-ar="نظام الحماية">Protection System</h3>
                    <p class="lang-text" data-en="Advanced anti-abuse and moderation tools for your Discord servers." data-ar="أدوات متقدمة للحماية والإشراف على سيرفرات الديسكورد.">
                        Advanced anti-abuse and moderation tools for your Discord servers.
                    </p>
                </div>

                <div class="card">
                    <i class="fa-solid fa-language fa-2x" style="color: var(--main-red); margin-bottom: 15px;"></i>
                    <h3 class="lang-text" data-en="Website Language" data-ar="لغة الموقع">Website Language</h3>
                    <p class="lang-text" data-en="Choose English or Arabic and the whole dashboard will switch instantly." data-ar="اختر الإنجليزية أو العربية وسيتحول الموقع بالكامل فورًا.">
                        Choose English or Arabic and the whole dashboard will switch instantly.
                    </p>
                </div>

                <div class="card">
                    <i class="fa-solid fa-server fa-2x" style="color: var(--main-red); margin-bottom: 15px;"></i>
                    <h3 class="lang-text" data-en="Manage Servers" data-ar="إدارة السيرفرات">Manage Servers</h3>
                    <p class="lang-text" data-en="Open the Servers page to manage the available Discord servers." data-ar="افتح صفحة السيرفرات لإدارة السيرفرات المتاحة.">
                        Open the Servers page to manage the available Discord servers.
                    </p>
                    <a href="/servers" class="btn-manage">
                        <span class="lang-text" data-en="Open Servers" data-ar="فتح السيرفرات">Open Servers</span>
                    </a>
                </div>
            </div>
        </div>
    </div>

    <script>
        function toggleSidebar() {
            const sidebar = document.getElementById("sidebar");
            const main = document.getElementById("main");
            const overlay = document.getElementById("overlay");

            if (window.innerWidth <= 768) {
                sidebar.classList.toggle("active");
                overlay.classList.toggle("active");
            } else {
                sidebar.classList.toggle("collapsed");
                main.classList.toggle("collapsed");
            }
        }

        function applyLanguage(lang) {
            const root = document.getElementById("htmlRoot");
            const switcher = document.getElementById("languageSwitcher");
            const elements = document.querySelectorAll(".lang-text");

            if (lang === "ar") {
                root.setAttribute("lang", "ar");
                root.setAttribute("dir", "rtl");
            } else {
                root.setAttribute("lang", "en");
                root.setAttribute("dir", "ltr");
            }

            elements.forEach(el => {
                el.textContent = el.getAttribute(`data-${lang}`);
            });

            if (switcher) switcher.value = lang;
            localStorage.setItem("siteLang", lang);
        }

        function setLanguage(lang) {
            applyLanguage(lang);
        }

        const savedLang = localStorage.getItem("siteLang") || "en";
        applyLanguage(savedLang);
    </script>
</body>
</html>
