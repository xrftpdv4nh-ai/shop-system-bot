<!DOCTYPE html>
<html lang="en" id="htmlRoot" dir="ltr">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>DealerX | Home</title>
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">
    <link rel="stylesheet" href="/style.css">
</head>
<body>

    <div class="overlay" id="overlay" onclick="toggleSidebar()"></div>

    <%- include('sidebar', { page: 'home' }) %>

    <div class="main" id="main">
        <div class="navbar dashboard-navbar">
            <i class="fa-solid fa-bars toggle-btn" onclick="toggleSidebar()"></i>

            <div class="user-section">
                <span class="username"><%= user.username %></span>
                <img
                    src="<%= user.avatar ? `https://cdn.discordapp.com/avatars/${user.discordId}/${user.avatar}.png` : 'https://cdn.discordapp.com/embed/avatars/0.png' %>"
                    class="avatar"
                    alt="avatar"
                    onerror="this.src='https://cdn.discordapp.com/embed/avatars/0.png'"
                >
            </div>
        </div>

        <div class="content">

            <div class="home-hero">
                <div class="home-hero-text">
                    <h1>Welcome back, <span><%= user.username %></span></h1>
                    <p>Manage your DealerX progress, track your activity, and claim your rewards from one place.</p>
                </div>

                <div class="quick-actions">
                    <a href="/servers" class="action-btn">
                        <i class="fa-solid fa-server"></i>
                        Open Servers
                    </a>

                    <a href="/daily" class="action-btn">
                        <i class="fa-solid fa-gift"></i>
                        Claim Daily
                    </a>
                </div>
            </div>

            <div class="overview-grid">

                <div class="overview-card large-card">
                    <div class="overview-head">
                        <div class="overview-icon red-icon">
                            <i class="fa-solid fa-crown"></i>
                        </div>
                        <div>
                            <h3>Crowns</h3>
                            <p>Your current economy balance</p>
                        </div>
                    </div>

                    <div class="overview-value"><%= Number(stats.crowns || 0).toLocaleString() %></div>
                </div>

                <div class="overview-card">
                    <div class="overview-head">
                        <div class="overview-icon gold-icon">
                            <i class="fa-solid fa-trophy"></i>
                        </div>
                        <div>
                            <h3>Global Rank</h3>
                            <p>Your current position</p>
                        </div>
                    </div>

                    <div class="overview-value">#<%= stats.rank || 1 %></div>
                </div>

                <div class="overview-card">
                    <div class="overview-head">
                        <div class="overview-icon blue-icon">
                            <i class="fa-solid fa-chart-simple"></i>
                        </div>
                        <div>
                            <h3>Usage</h3>
                            <p>Commands, messages and voice activity</p>
                        </div>
                    </div>

                    <div class="overview-value"><%= Number(stats.usage || 0).toLocaleString() %></div>
                </div>

                <div class="overview-card">
                    <div class="overview-head">
                        <div class="overview-icon pink-icon">
                            <i class="fa-solid fa-comments"></i>
                        </div>
                        <div>
                            <h3>Message Level</h3>
                            <p>Text activity progress</p>
                        </div>
                    </div>

                    <div class="overview-value"><%= stats.messageLevel || 1 %></div>
                    <div class="overview-sub">
                        <span>Messages:</span>
                        <strong><%= Number(stats.messageCount || 0).toLocaleString() %></strong>
                    </div>
                </div>

                <div class="overview-card">
                    <div class="overview-head">
                        <div class="overview-icon purple-icon">
                            <i class="fa-solid fa-microphone-lines"></i>
                        </div>
                        <div>
                            <h3>Voice Level</h3>
                            <p>Voice activity progress</p>
                        </div>
                    </div>

                    <div class="overview-value"><%= stats.voiceLevel || 1 %></div>
                    <div class="overview-sub">
                        <span>Voice Minutes:</span>
                        <strong><%= Number(stats.voiceMinutes || 0).toLocaleString() %></strong>
                    </div>
                </div>

                <div class="overview-card bot-card">
                    <div class="overview-head">
                        <div class="overview-icon green-icon">
                            <i class="fa-solid fa-robot"></i>
                        </div>
                        <div>
                            <h3>Bot Overview</h3>
                            <p>DealerX core information</p>
                        </div>
                    </div>

                    <div class="bot-description">
                        DealerX is a management and activity bot built for moderation, economy, automation, server tools, and a clean user dashboard experience.
                    </div>

                    <div class="bot-meta">
                        <div class="bot-meta-item">
                            <span>Message XP</span>
                            <strong><%= Number(stats.messageXp || 0).toLocaleString() %></strong>
                        </div>

                        <div class="bot-meta-item">
                            <span>Voice XP</span>
                            <strong><%= Number(stats.voiceXp || 0).toLocaleString() %></strong>
                        </div>

                        <div class="bot-meta-item">
                            <span>Commands Used</span>
                            <strong><%= Number(stats.commandUsage || 0).toLocaleString() %></strong>
                        </div>
                    </div>
                </div>

            </div>
        </div>
    </div>

    <script>
        function toggleSidebar() {
            const sidebar = document.getElementById("sidebar");
            const main = document.getElementById("main");
            const overlay = document.getElementById("overlay");

            if (window.innerWidth <= 768) {
                sidebar.classList.toggle("active");
                overlay.classList.toggle("active");
            } else {
                sidebar.classList.toggle("collapsed");
                main.classList.toggle("collapsed");
            }
        }
    </script>
</body>
</html>
