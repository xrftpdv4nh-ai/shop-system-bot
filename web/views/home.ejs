<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>DealerX | Home</title>
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.2/css/all.min.css">
    <link rel="stylesheet" href="/style.css">
</head>
<body>

    <div class="overlay" id="overlay" onclick="toggleSidebar()"></div>

    <%- include('sidebar', { page: 'home' }) %>

    <div class="main" id="main">
        <div class="navbar dashboard-navbar">
            <i class="fa-solid fa-bars toggle-btn" onclick="toggleSidebar()"></i>

            <div class="user-section">
                <span class="username"><%= user.username %></span>
                <img
                    src="<%= user.avatar ? `https://cdn.discordapp.com/avatars/${user.discordId}/${user.avatar}.png` : 'https://cdn.discordapp.com/embed/avatars/0.png' %>"
                    class="avatar"
                    alt="avatar"
                    onerror="this.src='https://cdn.discordapp.com/embed/avatars/0.png'"
                >
            </div>
        </div>

        <div class="content">
            <section class="dx-hero">
                <div class="dx-hero-left">
                    <div class="dx-badge">
                        <i class="fa-solid fa-bolt"></i>
                        DealerX Dashboard
                    </div>

                    <h1 class="dx-hero-title">
                        Welcome back, <span><%= user.username %></span>
                    </h1>

                    <p class="dx-hero-text">
                        Track your progress, manage your servers, claim daily rewards, and monitor your full DealerX activity from one premium dashboard.
                    </p>

                    <div class="dx-actions">
                        <a href="/servers" class="dx-btn dx-btn-primary">
                            <i class="fa-solid fa-server"></i>
                            Open Servers
                        </a>

                        <a href="/daily" class="dx-btn dx-btn-secondary">
                            <i class="fa-solid fa-gift"></i>
                            Claim Daily
                        </a>

                        <% if (isBotOwner) { %>
                            <a href="/owner" class="dx-btn dx-btn-secondary">
                                <i class="fa-solid fa-user-shield"></i>
                                Admin Panel
                            </a>
                        <% } %>
                    </div>
                </div>

                <div class="dx-hero-right">
                    <div class="dx-profile-card">
                        <img
                            src="<%= user.avatar ? `https://cdn.discordapp.com/avatars/${user.discordId}/${user.avatar}.png` : 'https://cdn.discordapp.com/embed/avatars/0.png' %>"
                            alt="avatar"
                            class="dx-profile-avatar"
                            onerror="this.src='https://cdn.discordapp.com/embed/avatars/0.png'"
                        >
                        <div class="dx-profile-meta">
                            <h3><%= user.username %></h3>
                            <p>
                                <% if (premium?.isPremium) { %>
                                    DealerX Premium User
                                <% } else { %>
                                    DealerX Standard User
                                <% } %>
                            </p>

                            <% if (isBotOwner) { %>
                                <div style="margin-top:10px;">
                                    <span style="display:inline-block; background:rgba(255,30,46,0.12); border:1px solid rgba(255,30,46,0.20); color:#ffb8be; padding:8px 12px; border-radius:999px; font-size:12px; font-weight:800;">
                                        Admin Access
                                    </span>
                                </div>
                            <% } %>
                        </div>
                    </div>
                </div>
            </section>

            <section class="dx-stats-grid">
                <div class="dx-stat-card dx-stat-large">
                    <div class="dx-stat-icon crown">
                        <i class="fa-solid fa-crown"></i>
                    </div>
                    <div class="dx-stat-content">
                        <h3>Crowns</h3>
                        <p>Your current balance</p>
                        <div class="dx-stat-value"><%= Number(stats.crowns || 0).toLocaleString() %></div>
                    </div>
                </div>

                <div class="dx-stat-card">
                    <div class="dx-stat-icon rank">
                        <i class="fa-solid fa-trophy"></i>
                    </div>
                    <div class="dx-stat-content">
                        <h3>Global Rank</h3>
                        <p>Position among all users</p>
                        <div class="dx-stat-value">#<%= stats.rank || 1 %></div>
                    </div>
                </div>

                <div class="dx-stat-card">
                    <div class="dx-stat-icon usage">
                        <i class="fa-solid fa-chart-simple"></i>
                    </div>
                    <div class="dx-stat-content">
                        <h3>Usage</h3>
                        <p>Commands, messages and voice</p>
                        <div class="dx-stat-value"><%= Number(stats.usage || 0).toLocaleString() %></div>
                    </div>
                </div>

                <div class="dx-stat-card">
                    <div class="dx-stat-icon msg">
                        <i class="fa-solid fa-comments"></i>
                    </div>
                    <div class="dx-stat-content">
                        <h3>Message Level</h3>
                        <p>Text activity progress</p>
                        <div class="dx-stat-value"><%= stats.messageLevel || 1 %></div>
                        <div class="dx-mini-line">Messages: <strong><%= Number(stats.messageCount || 0).toLocaleString() %></strong></div>
                    </div>
                </div>

                <div class="dx-stat-card">
                    <div class="dx-stat-icon voice">
                        <i class="fa-solid fa-microphone-lines"></i>
                    </div>
                    <div class="dx-stat-content">
                        <h3>Voice Level</h3>
                        <p>Voice activity progress</p>
                        <div class="dx-stat-value"><%= stats.voiceLevel || 1 %></div>
                        <div class="dx-mini-line">Voice Minutes: <strong><%= Number(stats.voiceMinutes || 0).toLocaleString() %></strong></div>
                    </div>
                </div>
            </section>

            <section class="dx-bottom-grid">
                <div class="dx-panel">
                    <div class="dx-panel-head">
                        <h3><i class="fa-solid fa-chart-line"></i> Progress</h3>
                        <span>Live overview</span>
                    </div>

                    <div class="dx-progress-block">
                        <div class="dx-progress-title">
                            <span>Message XP</span>
                            <strong><%= Number(stats.messageXp || 0).toLocaleString() %></strong>
                        </div>
                        <div class="dx-progress-bar">
                            <div class="dx-progress-fill" style="width: <%= Math.min(100, ((stats.messageXp || 0) % 1000) / 10) %>%"></div>
                        </div>
                    </div>

                    <div class="dx-progress-block">
                        <div class="dx-progress-title">
                            <span>Voice XP</span>
                            <strong><%= Number(stats.voiceXp || 0).toLocaleString() %></strong>
                        </div>
                        <div class="dx-progress-bar">
                            <div class="dx-progress-fill alt" style="width: <%= Math.min(100, ((stats.voiceXp || 0) % 1000) / 10) %>%"></div>
                        </div>
                    </div>

                    <div class="dx-progress-block">
                        <div class="dx-progress-title">
                            <span>Commands Used</span>
                            <strong><%= Number(stats.commandUsage || 0).toLocaleString() %></strong>
                        </div>
                        <div class="dx-progress-bar">
                            <div class="dx-progress-fill soft" style="width: <%= Math.min(100, ((stats.commandUsage || 0) % 1000) / 10) %>%"></div>
                        </div>
                    </div>
                </div>

                <div class="dx-panel">
                    <div class="dx-panel-head">
                        <h3><i class="fa-solid fa-robot"></i> DealerX Overview</h3>
                        <span>Core information</span>
                    </div>

                    <p class="dx-overview-text">
                        DealerX is a premium Discord bot built for moderation, economy, activity, automation, and dashboard-based server control with a dark luxury experience.
                    </p>

                    <div class="dx-info-grid">
                        <div class="dx-info-box">
                            <span>Plan</span>
                            <strong><%= premium?.isPremium ? 'Premium' : 'Standard' %></strong>
                        </div>

                        <div class="dx-info-box">
                            <span>Message XP</span>
                            <strong><%= Number(stats.messageXp || 0).toLocaleString() %></strong>
                        </div>

                        <div class="dx-info-box">
                            <span>Voice XP</span>
                            <strong><%= Number(stats.voiceXp || 0).toLocaleString() %></strong>
                        </div>

                        <div class="dx-info-box">
                            <span>Commands</span>
                            <strong><%= Number(stats.commandUsage || 0).toLocaleString() %></strong>
                        </div>

                        <div class="dx-info-box">
                            <span>Crowns</span>
                            <strong><%= Number(stats.crowns || 0).toLocaleString() %></strong>
                        </div>

                        <% if (isBotOwner) { %>
                            <div class="dx-info-box">
                                <span>Access Level</span>
                                <strong>Admin</strong>
                            </div>
                        <% } %>
                    </div>
                </div>
            </section>
        </div>
    </div>

    <script>
        function toggleSidebar() {
            const sidebar = document.getElementById("sidebar");
            const main = document.getElementById("main");
            const overlay = document.getElementById("overlay");

            if (window.innerWidth <= 768) {
                sidebar.classList.toggle("active");
                overlay.classList.toggle("active");
            } else {
                sidebar.classList.toggle("collapsed");
                main.classList.toggle("collapsed");
            }
        }
    </script>
</body>
</html>
